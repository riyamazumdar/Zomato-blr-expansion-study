    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "df= pd.read_csv('data/zomato_clean.csv')\n",
    "print(\"Shape:\", df.shape)\n",
    "\n",
    "conn=sqlite3.connect('data/zomato.db')\n",
    "df.to_sql('restaurants', conn, if_exists='replace', index=False)\n",
    "\n",
    "print(\"Done!\")\n",
    "conn.close()\n"
   ]
  }
